# KP Agency OS - Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Supabase
SUPABASE_URL=https://tzrxdhysymshetxkvcto.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here        # Safe for browser/frontend use
SUPABASE_SERVICE_KEY=your_service_key_here  # Server-only, never in browser code

# n8n
N8N_API_URL=https://n8n.dynamorate.com/api/v1
N8N_API_KEY=your_n8n_api_key_here

# AI APIs
ANTHROPIC_API_KEY=your_anthropic_key_here
PERPLEXITY_API_KEY=your_perplexity_key_here

# Google (for lead agent)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Webhooks
APPROVAL_WEBHOOK_URL=https://n8n.dynamorate.com/webhook/kp-approve
